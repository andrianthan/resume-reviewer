# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Channel ID where the bot posts the "Review my resume" panel
REVIEW_CHANNEL_ID=0

# Google Gemini API key (https://aistudio.google.com/apikey)
# Optional — without it, evaluator runs in deterministic mode (no LLM judge)
GEMINI_API_KEY=

# AWS deployment (set after `sam deploy`)
RESUME_API_URL=
RESUME_PDF_BUCKET=

# AWS credentials: prefer `aws configure` (~/.aws/credentials) over env vars.
# Required env: AWS_REGION only.
