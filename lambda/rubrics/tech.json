  "major": "tech",
  "label": "Tech / Software Engineering",
  "version": 2,
  "categories": [
    {
      "key": "basics",
      "label": "Basics & Education",
      "weight": 0.10,
      "rubric": "Score 0-10 on contact info, education (school, major, grad date, GPA if strong), and overall presentation. Strong: clear degree + grad date + contact. Weak: missing grad date, no GPA context, typos in school names.",
      "red_flags": ["no_graduation_date", "no_school_listed"]
    },
    {
      "key": "education",
      "label": "Coursework & Learning",
      "weight": 0.10,
      "rubric": "Score 0-10 on relevant CS coursework: data structures, algorithms, OS, distributed systems, ML, databases. Strong: specific named courses with grades or projects tied to them. Weak: no coursework section or only generic 'Intro to CS'.",
      "red_flags": ["no_relevant_coursework"]
    },
    {
      "key": "technical_skills",
      "label": "Technical Skills",
      "weight": 0.20,
      "rubric": "Score 0-20 on languages, frameworks, tools, infra. Strong: production stack (Python/Go/Rust/Java/TS), cloud (AWS/GCP), Docker/K8s, SQL, Git. Weak: only 'Microsoft Office' or no skills section.",
      "red_flags": ["missing_git", "no_languages_listed", "only_office_tools"]
    },
    {
      "key": "self_projects",
      "label": "Self / Side Projects",
      "weight": 0.15,
      "rubric": "Score 0-15 on side projects: shipped product, real users, open source. Strong: personal site, deployed app with users, technical blog. Weak: no projects outside class.",
      "red_flags": ["no_projects_outside_class"]
    },
    {
      "key": "open_source",
      "label": "Open Source",
      "weight": 0.10,
      "rubric": "Score 0-10 on open-source contributions: PRs merged to big projects, personal repos with stars, Hacktoberfest, GSoC. Strong: real merged PRs, maintainer of a small project. Weak: zero.",
      "red_flags": []
    },
    {
      "key": "production",
      "label": "Production / Work Experience",
      "weight": 0.20,
      "rubric": "Score 0-20 on internships, co-ops, research, or production engineering. Strong: shipped code to real users, on-call, PRs reviewed, scale (users/requests/data). Weak: 'helped with testing' only.",
      "red_flags": ["no_engineering_internship", "all_bullets_vague"]
    },
    {
      "key": "awards",
      "label": "Awards & Recognition",
      "weight": 0.10,
      "rubric": "Score 0-10 on hackathon wins/finalists, ICPC, dean's list, scholarships, research publications. Bonus for selective recognition (TreeHacks, CalHacks, MIT/Harvard prize).",
      "red_flags": []
    },
    {
      "key": "impact",
      "label": "Quantified Impact",
      "weight": 0.05,
      "rubric": "Score 0-5 on % of bullets with numbers. Tech values: PRs merged, latency reduced, requests/sec, test coverage, build time. Numbers > words.",
      "red_flags": ["no_quantified_bullets"]
    }
  ],
