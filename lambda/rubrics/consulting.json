  "major": "consulting",
  "label": "Consulting / Strategy",
  "version": 1,
  "categories": [
    {
      "key": "impact",
      "label": "Quantified Impact",
      "weight": 0.30,
      "rubric": "Score 0-40 on % of bullets with numbers ($, %, x, scope, headcount). Consulting screens on outcome magnitude — deal/policy/ops results, team size, timeline compressed, stakeholder count. 'Helped with a case' is invisible; '$2M cost reduction identified across 3 workstreams' is not.",
      "red_flags": ["no_quantified_bullets_in_work", "all_bullets_vague", "duty_statements_without_outcomes"]
    },
    {
      "key": "domain_fit",
      "label": "Consulting Domain Fit",
      "weight": 0.25,
      "rubric": "Score 0-25 on consulting relevance of work + coursework + extracurriculars. Strong: case club officer, case competition win, MBB/OC&C/LEK/Kearney/Strategy& exposure, IB/PE/PM internship, framework-driven project. Weak: retail/food service framed without analytical framing.",
      "red_flags": ["no_consulting_signal", "no_relevant_coursework", "no_case_prep_evidence"]
    },
    {
      "key": "technical",
      "label": "Technical (Consulting)",
      "weight": 0.15,
      "rubric": "Score 0-15 on Excel, PowerPoint (pyramid principle, slide design), data tools (SQL, Python, Tableau, Power BI). Pyramid principle + MECE structuring is non-negotiable. Bonus: business case frameworks (Porter, 4Cs), market sizing, financial modeling basics.",
      "red_flags": ["missing_excel", "missing_powerpoint", "no_framework_or_structuring_evidence"]
    },
    {
      "key": "format",
      "label": "Format / ATS",
      "weight": 0.10,
      "rubric": "Score 0-10 on 1-page rule, clean sections, no tables/columns, .docx + .pdf export tested, consistent date formatting. Recruiters spend 30 seconds on first pass — whitespace and scannability matter.",
      "red_flags": ["two_column_layout", "graphics_in_header", "inconsistent_dates"]
    },
    {
      "key": "brand",
      "label": "Brand Consistency",
      "weight": 0.10,
      "rubric": "Score 0-10 on LinkedIn headline + experience matching resume (school, role titles, dates). Target-school pipeline recruiters cross-check LinkedIn; mismatches raise red flags.",
      "red_flags": ["linkedin_role_mismatch", "no_linkedin_url"]
    },
    {
      "key": "extras",
      "label": "Extras & Leadership",
      "weight": 0.10,
      "rubric": "Score 0-10 on consulting club officer role, case competition win (Mercer, P&G, Hult, UVA), leadership outside work, second language, diversity org, pro bono (180 DC, Net Impact), second-language fluency for global offices.",
      "red_flags": []
    }
  ],
